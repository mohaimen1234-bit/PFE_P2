# =============================================================
# secrets.yaml.example
# Template for sensitive credentials. 
# Copy this to secrets.yaml and fill in the values.
# =============================================================
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: cmms
type: Opaque
stringData:
  POSTGRES_DB: "cmms_db"
  POSTGRES_USER: "your_db_user"
  POSTGRES_PASSWORD: "your_db_password"
  BOOTSTRAP_ADMIN_PASSWORD: "your_admin_password"
